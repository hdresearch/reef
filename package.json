{
  "name": "@versdotsh/reef",
  "version": "0.3.0",
  "description": "Self-improving fleet infrastructure — the minimum kernel agents need to build their own tools",
  "type": "module",
  "scripts": {
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "dev": "bun --watch run src/main.ts",
    "start": "bun run src/main.ts",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --fix --unsafe ."
  },
  "keywords": ["pi-package"],
  "pi": {
    "extensions": [
      "./src/extension.ts",
      "./extensions/reminders.ts"
    ],
    "skills": ["./skills"]
  },
  "dependencies": {
    "@hdresearch/pi-v": "file:../pi-vers",
    "hono": "^4.12.2",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@mariozechner/pi-ai": "^0.54.2",
    "@mariozechner/pi-coding-agent": "^0.54.2",
    "@sinclair/typebox": "^0.34.48",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
